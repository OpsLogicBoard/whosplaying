# Secrets for the Stripe edge functions.
# Local: copy to supabase/functions/.env for `supabase functions serve`.
# Deployed: set via `supabase secrets set --env-file supabase/functions/.env`.
# (SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically when deployed.)

# TEST key while building. Swap to the live key only at launch.
STRIPE_SECRET_KEY=sk_test_xxx
# From the Stripe webhook endpoint (whsec_…) pointing at /functions/v1/stripe-webhook.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price IDs (config, not secret) — created by scripts/stripe-setup.mjs (test mode).
STRIPE_PRICE_VENUE_PRO_MONTHLY=price_1TiS4jLKn5GLQMcmTXei9jj8
STRIPE_PRICE_VENUE_PRO_FOUNDING_MONTHLY=price_1TiS4kLKn5GLQMcm84inBRRt
STRIPE_PRICE_VENUE_ADDITIONAL_MONTHLY=price_1TiS4kLKn5GLQMcmsxayvjQY
STRIPE_PRICE_BOOST_ONE_TIME=price_1TiS4lLKn5GLQMcmF1Jwos8U
