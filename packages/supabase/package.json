{
  "name": "@whosplaying/supabase",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./queries/*": "./src/queries/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "gen-types": "supabase gen types typescript --local > src/types.ts",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "@whosplaying/config": "workspace:*"
  }
}
